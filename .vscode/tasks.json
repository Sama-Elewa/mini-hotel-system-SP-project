{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Crow Server",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I", "./",
                "-I", "./asio",
                "-std=c++17",
                "-pthread",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-lws2_32",
                "-lMswsock",
                "-lwsock32"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build Crow server using local crow folder"
        }
    ]
}